# LLM provider and model for Azure chatbot backend
# Format: provider:model_name
# Options: openai:gpt-4o-mini  |  openai:gpt-4o  |  ollama:llama3.2
FORWARD_CHAT_MODEL=openai:gpt-4o-mini

# API key for the chosen LLM provider
OPENAI_API_KEY=your-key-here

# Access code baked into chatbot JS at generation time (not a runtime secret)
# Rotate each semester by regenerating with a new value
ASEN3501_ACCESS_CODE=your-access-code-here

# Flask/FastAPI session secret for Azure deployment
APP_SECRET_KEY=your-long-random-string-here
